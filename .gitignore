*.mov
*.wav
*.mp3
*.m4a

# 生成物の画像 (再生成可能)
results/*.png

# Python キャッシュ
__pycache__/
*.pyc

# uv 仮想環境 (uv.lock はコミットする)
.venv/

# IDE 設定
.idea/

# レビューツールの生成物
results/*.html
*labels_review*.tsv

# LaTeX ビルド生成物
docs/*.aux
docs/*.log
docs/*.out
docs/paper.pdf
docs/aaa
